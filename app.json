{
  "expo": {
    "name": "ecommerco.ai",
    "slug": "ecommerco-ai",
    "version": "1.0.0",
    "scheme": "ecommerco",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.ecommerco.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "ai.ecommerco.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "description": "Imperial Enterprise & Brokerage Platform",
      "shortName": "ecommerco",
      "themeColor": "#FFD400",
      "backgroundColor": "#000000",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "en"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset"
    ]
  }
}
